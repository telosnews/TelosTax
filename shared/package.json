{
  "name": "@telostax/engine",
  "version": "0.1.0",
  "description": "Open-source federal tax calculation engine for the 2025 tax year. Pure TypeScript, zero dependencies.",
  "license": "MIT",
  "author": "TelosTax",
  "repository": {
    "type": "git",
    "url": "https://github.com/telostax/engine"
  },
  "keywords": [
    "tax",
    "taxes",
    "1040",
    "federal",
    "irs",
    "tax-calculator",
    "tax-engine",
    "self-employment",
    "schedule-c",
    "eitc",
    "open-source"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "fast-check": "^4.5.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
